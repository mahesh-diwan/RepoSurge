---
const LOGOS = [
  { slug: 'vercel', name: 'Vercel' },
  { slug: 'github', name: 'GitHub' },
  { slug: 'rust', name: 'Rust' },
  { slug: 'go', name: 'Go' },
  { slug: 'python', name: 'Python' },
  { slug: 'typescript', name: 'TypeScript' },
];
---
<section class="border-t border-bone/20 py-8">
  <div class="max-w-7xl mx-auto px-4">
    <p class="text-bone/40 text-xs tracking-widest uppercase mb-4 text-center">
      Used by developers at
    </p>
    <div class="flex flex-wrap items-center justify-center gap-8 opacity-60">
      {LOGOS.map((logo) => (
        <img
          src={`https://cdn.simpleicons.org/${logo.slug}/ffffff`}
          alt={`${logo.name} logo`}
          class="h-8 w-auto transition-opacity hover:opacity-100"
          loading="lazy"
        />
      ))}
    </div>
  </div>
</section>
